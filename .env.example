# Copy this to a real .env and fill it in. NO secrets are committed.
#
# NOTE: on the original dev machine `.env` is a *directory* containing a file named `.env`
# (so the real path is .env/.env); src/airquality/db.py looks there first. A plain top-level
# `.env` file works just as well — python-dotenv will find either.

# --- Postgres (required) ---
# A literal '@' in the password is fine: the app parses the URL with urlsplit, not libpq.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/airquality

# --- AWS (optional) ---
# Credentials are normally read from ~/.aws or a project-local .aws/ folder. Only set these
# if you prefer env vars. Region and queue name are overridable here too.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
SQS_QUEUE_NAME=openaq-sarthak
